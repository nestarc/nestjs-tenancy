{
  "name": "@nestarc/tenancy",
  "version": "0.3.0",
  "description": "Multi-tenancy module for NestJS with PostgreSQL Row Level Security (RLS) and Prisma support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "tenancy": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "printf '#!/usr/bin/env node\\n' | cat - dist/cli/index.js > dist/cli/index.tmp && mv dist/cli/index.tmp dist/cli/index.js",
    "test": "jest --testPathIgnorePatterns=e2e",
    "test:watch": "jest --watch --testPathIgnorePatterns=e2e",
    "test:cov": "jest --coverage --testPathIgnorePatterns=e2e",
    "test:e2e": "docker compose up -d --wait && prisma generate --schema=test/e2e/schema.prisma && jest --testPathPattern=e2e --runInBand; EXIT=$?; docker compose down; exit $EXIT",
    "lint": "tsc --noEmit && eslint src/ test/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "multi-tenancy",
    "tenancy",
    "rls",
    "row-level-security",
    "prisma",
    "postgresql",
    "saas"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ksyq12/nestjs-tenancy"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.1.0",
    "jest": "^29.0.0",
    "pg": "^8.13.0",
    "prisma": "^6.19.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "psl": "^1.15.0"
  }
}
