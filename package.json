{
  "name": "@nestarc/tenancy",
  "version": "0.13.0",
  "description": "Multi-tenancy module for NestJS with PostgreSQL Row Level Security (RLS) and Prisma support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "cache": [
        "dist/cache/index.d.ts"
      ],
      "testing": [
        "dist/testing/index.d.ts"
      ]
    }
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "tenancy": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node scripts/ensure-cli-shebang.js",
    "test": "jest --testPathIgnorePatterns=e2e",
    "test:watch": "jest --watch --testPathIgnorePatterns=e2e",
    "test:cov": "jest --coverage --testPathIgnorePatterns=e2e",
    "test:e2e": "node scripts/test-e2e.js",
    "bench": "npx ts-node benchmarks/rls-overhead.ts",
    "lint": "tsc --noEmit && eslint src/ test/",
    "prepack": "npm run build"
  },
  "keywords": [
    "nestjs",
    "multi-tenancy",
    "multi-tenant",
    "tenancy",
    "tenant-isolation",
    "rls",
    "row-level-security",
    "prisma",
    "postgresql",
    "saas",
    "saas-backend",
    "nestjs-module"
  ],
  "license": "MIT",
  "homepage": "https://nestarc.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestarc/nestjs-tenancy"
  },
  "peerDependencies": {
    "@nestjs/cache-manager": "^2.0.0 || ^3.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0",
    "@opentelemetry/api": "^1.0.0",
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "cache-manager": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/cache-manager": {
      "optional": true
    },
    "@nestjs/event-emitter": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "cache-manager": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.0",
    "@types/prompts": "^2.4.9",
    "@types/supertest": "^7.2.0",
    "cache-manager": "^7.2.8",
    "eslint": "^10.1.0",
    "jest": "^30.4.2",
    "pg": "^8.13.0",
    "prisma": "^6.19.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "psl": "^1.15.0",
    "prompts": "^2.4.2"
  }
}
